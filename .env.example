# Copia este archivo a .env y ajusta los valores antes de desplegar.

# === Django ===
DJANGO_SECRET_KEY=cambia-esta-clave-por-una-aleatoria-de-50-caracteres
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIMEZONE=America/New_York

# Para HTTPS en producción detrás de un proxy:
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_CSRF_TRUSTED_ORIGINS=https://tudominio.com

# === Datos del negocio (opcionales: hay defaults en settings.py) ===
SITE_PHONE=+1 (555) 123-4567
SITE_WHATSAPP=15551234567
SITE_EMAIL=hello@alambranails.com
SITE_ADDRESS=123 Beauty Avenue, New York, NY 10001
SITE_INSTAGRAM=alambra.nails
SITE_HORARIO=Mon–Sat · 9:00 AM — 7:00 PM

# === PostgreSQL (opcional, descomenta para usarlo) ===
